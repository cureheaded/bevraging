# Supabase — vind je in Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Admin wachtwoord (kies zelf iets sterks)
